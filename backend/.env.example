# SNAPPY backend environment variables. Copy to .env and fill in real values.

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://user:password@host:5432/postgres

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- App ---
SECRET_KEY=change-me
INVOICE_PREFIX=LAW
CURRENCY=INR
DEFAULT_TAX_RATE=18

# --- Backups ---
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

# --- Admin panel (server-rendered at /admin) ---
# ADMIN_PASSWORD is REQUIRED — /admin returns 503 if it is unset.
# ADMIN_USERNAME defaults to "admin".
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# --- Legal Feed ingestion ---
# Shared secret the Cloud Scheduler job sends as the X-Ingest-Secret header
# when calling POST /api/v1/legal-feed/ingest. Required for ingestion to run.
LEGAL_FEED_INGEST_SECRET=change-me-random-secret

# --- Legal Feed enrichment (OpenAI) ---
# If OPENAI_API_KEY is unset, ingestion still runs but items are NOT enriched
# (no headline/tldr/topics/importance/embedding). Only public RSS title/summary
# is ever sent to OpenAI — never client/firm/invoice data.
OPENAI_API_KEY=
LEGAL_FEED_ENRICH_MODEL=gpt-4o-mini
LEGAL_FEED_EMBED_MODEL=text-embedding-3-small
